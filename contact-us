<main id="main-content">
<style>
/* ── Contact Page Styles ── */
.contact-page {
  max-width: 680px;
  margin: 0 auto;
  padding: 60px 20px 80px;
}

.contact-heading {
  font-size: 2.2rem;
  color: #2c3e50;
  margin: 0 0 20px 0;
  font-weight: 700;
  text-align: center;
}

.contact-intro {
  color: #4a5568;
  font-size: 1.05rem;
  line-height: 1.7;
  text-align: center;
  margin: 0 0 40px 0;
}

.contact-intro a {
  color: #e74c3c;
  text-decoration: none;
  font-weight: 600;
}

.contact-intro a:hover {
  text-decoration: underline;
}

/* ── Form Card ── */
.contact-form-card {
  background: #ffffff;
  border-radius: 12px;
  padding: 35px 30px;
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
  border: 1px solid #e2e8f0;
}

.contact-form {
  display: flex;
  flex-direction: column;
  gap: 22px;
}

.form-group {
  display: flex;
  flex-direction: column;
}

.form-label {
  font-weight: 600;
  font-size: 0.92rem;
  color: #2d3748;
  margin-bottom: 8px;
}

.form-label .required {
  color: #e74c3c;
  margin-left: 2px;
}

.form-input,
.form-textarea {
  width: 100%;
  padding: 12px 15px;
  border: 2px solid #e2e8f0;
  border-radius: 8px;
  font-size: 0.95rem;
  font-family: inherit;
  background: #f7fafc;
  color: #2d3748;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.form-input:focus,
.form-textarea:focus {
  outline: none;
  border-color: #3498db;
  background: #fff;
  box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.12);
}

.form-input.error,
.form-textarea.error {
  border-color: #e74c3c;
}

.form-textarea {
  min-height: 140px;
  resize: vertical;
}

.form-error {
  display: none;
  color: #e74c3c;
  font-size: 0.84rem;
  margin-top: 5px;
  font-weight: 500;
}

.form-error.show {
  display: block;
}

/* ── Submit Button ── */
.form-submit-wrapper {
  text-align: center;
  margin-top: 8px;
}

.form-submit {
  padding: 14px 40px;
  background: linear-gradient(135deg, #e74c3c, #c0392b);
  color: #fff;
  border: none;
  border-radius: 8px;
  font-weight: 600;
  font-size: 1rem;
  font-family: inherit;
  cursor: pointer;
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.form-submit:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 5px 15px rgba(231, 76, 60, 0.3);
}

.form-submit:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.form-submit.loading i {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── Success / Error Messages ── */
.form-message {
  display: none;
  padding: 16px 20px;
  border-radius: 8px;
  margin-bottom: 22px;
  text-align: center;
  font-size: 0.95rem;
  line-height: 1.5;
}

.form-message.success {
  background: #d4f4dd;
  border: 2px solid #48bb78;
  color: #22543d;
}

.form-message.error-msg {
  background: #fde8e8;
  border: 2px solid #e74c3c;
  color: #742a2a;
}

.form-message.show {
  display: block;
}

/* ── Responsive ── */
@media (min-width: 768px) {
  .contact-page {
    padding: 80px 20px 100px;
  }
  .contact-heading {
    font-size: 2.6rem;
  }
  .contact-form-card {
    padding: 40px 38px;
  }
}
</style>

<div class="contact-page">

  <h1 class="contact-heading">Contact Us</h1>

  <p class="contact-intro">
    Have questions about peptide dosages, protocols, or anything else on our site?
    We'd love to hear from you! Use the form below to send us a message and we'll
    get back to you as soon as we can. You can also reach us directly by email at
    <a href="mailto:info@pep-dose.com">info@pep-dose.com</a>.
  </p>

  <div class="contact-form-card">

    <div id="formMessage" class="form-message"></div>

    <form id="contactForm" class="contact-form"
          action="https://formsubmit.co/info@pep-dose.com" method="POST">

      <!-- Formsubmit.co configuration -->
      <input type="hidden" name="_subject" value="New message from pep-dose.com contact form">
      <input type="hidden" name="_captcha" value="true">
      <input type="hidden" name="_next" value="https://pep-dose.com/contact-us/?submitted=true">
      <input type="hidden" name="_template" value="table">
      <input type="text" name="_honey" style="display:none">

      <!-- Name -->
      <div class="form-group">
        <label for="name" class="form-label">Name <span class="required">*</span></label>
        <input type="text" id="name" name="name" class="form-input" required
               placeholder="Your name">
        <span class="form-error">Please enter your name</span>
      </div>

      <!-- Email -->
      <div class="form-group">
        <label for="email" class="form-label">Email <span class="required">*</span></label>
        <input type="email" id="email" name="email" class="form-input" required
               placeholder="Your email address">
        <span class="form-error">Please enter a valid email address</span>
      </div>

      <!-- Comments -->
      <div class="form-group">
        <label for="comments" class="form-label">Comments <span class="required">*</span></label>
        <textarea id="comments" name="comments" class="form-textarea" rows="6" required
                  placeholder="How can we help you?"></textarea>
        <span class="form-error">Please enter your comments</span>
      </div>

      <!-- Submit -->
      <div class="form-submit-wrapper">
        <button type="submit" class="form-submit">
          <i class="fas fa-paper-plane"></i> Send Message
        </button>
      </div>

    </form>
  </div>

</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var params = new URLSearchParams(window.location.search);
  var msg = document.getElementById('formMessage');

  // Show success message after Formsubmit.co redirect
  if (params.get('submitted') === 'true') {
    msg.innerHTML = '<i class="fas fa-check-circle"></i> Thank you for your message! We\u2019ll get back to you as soon as possible.';
    msg.className = 'form-message success show';
    msg.scrollIntoView({ behavior: 'smooth', block: 'center' });
    window.history.replaceState({}, '', window.location.pathname);
  }

  // Client-side validation before POST
  var form = document.getElementById('contactForm');
  form.addEventListener('submit', function(e) {
    var isValid = true;

    form.querySelectorAll('[required]').forEach(function(field) {
      field.classList.remove('error');
      var err = field.nextElementSibling;
      if (err) err.classList.remove('show');

      if (!field.value.trim()) {
        field.classList.add('error');
        if (err) err.classList.add('show');
        isValid = false;
      }

      if (field.type === 'email' && field.value.trim()) {
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(field.value)) {
          field.classList.add('error');
          if (err) err.classList.add('show');
          isValid = false;
        }
      }
    });

    if (!isValid) {
      e.preventDefault();
    }
  });

  // Clear error styling on input
  form.querySelectorAll('.form-input, .form-textarea').forEach(function(input) {
    input.addEventListener('input', function() {
      if (this.value.trim()) {
        this.classList.remove('error');
        var err = this.nextElementSibling;
        if (err) err.classList.remove('show');
      }
    });
  });
});
</script>
</main>

