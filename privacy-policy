    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
  }

  /* Section Blocks */
  .section-block {
    background: linear-gradient(135deg, var(--page-light-bg) 0%, #ffffff 100%);
    border-radius: 10px;
    padding: 18px 15px;
    margin-bottom: 20px;
    box-shadow: var(--page-shadow-sm);
    border: 1px solid var(--page-border);
  }

  /* Dosing & Reconstitution Wrapper */
  .dosing-recon-wrapper {
    margin: 25px -5px;
    padding: 0;
    background: transparent;
  }

  .dosing-recon-wrapper .dr-container {
    max-width: 100%;
    margin: 0;
    background: linear-gradient(135deg, #f8fbff 0%, #ffffff 100%);
    border-radius: 10px;
    overflow: hidden;
    box-shadow: var(--page-shadow-md);
    border: 1px solid var(--page-border);
  }

  .dosing-recon-wrapper header {
    padding: 20px 15px;
    background: linear-gradient(135deg, var(--page-primary), #5ba3e0);
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .dosing-recon-wrapper header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='40' height='40' viewBox='0 0 40 40' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M20 20L0 0v20h20zm0 0l20 20V20H20zm0 0L0 40h20V20zm0 0l20-20H20v20z'/%3E%3C/g%3E%3C/svg%3E");
    opacity: 0.3;
  }

  .dosing-recon-wrapper header > div {
    position: relative;
    z-index: 1;
  }

  .dosing-recon-wrapper header h2 {
    font-size: 1.3rem;
    margin: 0;
    color: #fff;
    border: none !important;
    padding: 0 !important;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .dosing-recon-wrapper header h2 i {
    font-size: 1.2rem;
  }

  .dosing-recon-wrapper header h2::after {
    display: none;
  }

  .dosing-recon-wrapper header p {
    font-size: 0.9rem;
    margin: 8px 0 0 0;
    opacity: 0.95;
    color: #e8f4ff;
    font-weight: 400;
    letter-spacing: 0.3px;
  }

  .dosing-recon-wrapper section {
    padding: 20px 15px;
    border-bottom: 1px solid var(--page-border);
    background: #fff;
  }
  
  .dosing-recon-wrapper section:last-of-type {
    border-bottom: none;
  }

  .dosing-recon-wrapper section h2 {
    font-size: 1.15rem;
    margin-bottom: 15px;
    color: var(--page-secondary);
    border-left: 4px solid var(--page-accent);
    padding-left: 12px;
    border-bottom: none;
    font-weight: 600;
  }

  .dosing-recon-wrapper section h2::after {
    display: none;
  }

  .dosing-recon-wrapper table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 15px 0;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    background: #fff;
  }

  .dosing-recon-wrapper thead {
    background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
  }

  .dosing-recon-wrapper th {
    color: white !important;
    padding: 10px 8px;
    text-align: left;
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.75rem;
    letter-spacing: 0.8px;
    border: none;
  }

  .dosing-recon-wrapper td {
    padding: 10px 8px;
    border-bottom: 1px solid #f0f0f0;
    background: #fff;
    font-size: 0.85rem;
    color: var(--page-text);
  }

  .dosing-recon-wrapper tr:last-child td {
    border-bottom: none;
  }

  .dosing-recon-wrapper tr:hover td {
    background: #f8fbff;
  }

  .dosing-recon-wrapper tbody tr:nth-child(even) td {
    background: #fafbfc;
  }

  .dosing-recon-wrapper section p {
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--page-text);
    margin-bottom: 15px;
  }

  .dosing-recon-wrapper section ol {
    margin: 15px 0;
    padding-left: 20px;
  }

  .dosing-recon-wrapper section ol li {
    margin-bottom: 10px;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--page-text);
  }

  .dosing-recon-wrapper footer {
    padding: 15px;
    background: linear-gradient(135deg, #fef9e7, #fdf6e3);
    border-top: 2px solid #fcefc0;
    text-align: center;
    font-style: italic;
    color: #7a6736;
    font-size: 0.85rem;
  }

  .dosing-recon-wrapper footer p {
    margin: 0;
  }

  /* Image Gallery */
  .image-gallery {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
    margin: 18px 0;
  }

  .product-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
    padding: 12px;
    border-radius: 8px;
    background: #fff;
    box-shadow: var(--page-shadow-sm);
    transition: all 0.3s ease;
    border: 1px solid var(--page-border);
    min-height: 180px;
  }

  .product-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--page-shadow-md);
  }

  .product-card img {
    width: 100%;
    max-width: 100px;
    height: 100px;
    object-fit: cover;
    border-radius: 6px;
    margin-bottom: 10px;
  }

  .product-card a {
    display: inline-block;
    background: linear-gradient(135deg, var(--page-accent), #c0392b);
    color: #fff !important;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: 20px;
    text-decoration: none !important;
    transition: all 0.3s ease;
    border: none !important;
    font-size: 0.8rem;
    text-align: center;
    width: 100%;
    max-width: 110px;
  }

  .product-card a:hover {
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(231, 76, 60, 0.3);
  }

  /* Important Note */
  .important-note {
    background: var(--page-note-bg);
    border: 2px solid var(--page-note-border);
    border-radius: 8px;
    padding: 16px;
    margin: 20px 0;
    color: #7a6736;
  }
  
  .important-note h3 {
    margin-top: 0;
    margin-bottom: 8px;
    color: #7a6736;
    font-size: 1.05rem;
  }
  
  .important-note p {
    margin: 0;
    font-size: 0.9rem;
  }

  /* Supplier Info */
  .supplier-info {
    background: linear-gradient(135deg, #e8f4f8 0%, #ffffff 100%);
    border-radius: 8px;
    padding: 16px;
    margin: 20px 0;
    box-shadow: var(--page-shadow-sm);
    border-left: 5px solid var(--page-accent);
  }

  /* References Section */
  .references-section {
    margin-top: 25px;
    padding: 0;
    background: transparent;
  }
  
  .references-section h2 {
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 3px solid var(--page-accent);
  }

  .reference-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .reference-list li {
    margin-bottom: 12px;
    padding: 12px;
    background: linear-gradient(135deg, #f8fbff 0%, #ffffff 100%);
    border-radius: 8px;
    border-left: 3px solid var(--page-primary);
    box-shadow: var(--page-shadow-sm);
    transition: all 0.3s ease;
  }

  .reference-list li:hover {
    transform: translateX(2px);
    box-shadow: var(--page-shadow-md);
  }

  .ref-line {
    display: flex;
    align-items: flex-start;
    margin-bottom: 8px;
    color: var(--page-heading);
    flex-wrap: wrap;
    font-size: 0.9rem;
  }

  .ref-line i {
    color: var(--page-accent);
    margin-right: 8px;
    margin-top: 2px;
    font-size: 0.8rem;
  }

  .ref-line strong {
    color: var(--page-secondary);
    font-weight: 600;
    margin-right: 5px;
  }

  .view-source {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 5px 12px;
    background: linear-gradient(135deg, var(--page-accent), #c0392b);
    color: white !important;
    border-radius: 20px;
    text-decoration: none !important;
    transition: all 0.3s ease;
    font-size: 0.8rem;
    font-weight: 500;
    border: none !important;
  }

  .view-source:hover {
    transform: translateY(-1px);
    box-shadow: 0 3px 10px rgba(231, 76, 60, 0.3);
  }

  /* Blockquote */
  .page-content blockquote {
    border-left: 5px solid var(--page-accent);
    background: linear-gradient(90deg, rgba(231,76,60,0.05) 0%, transparent 100%);
    padding: 18px 20px;
    margin: 20px 0;
    border-radius: 6px;
    font-style: italic;
    color: var(--page-heading);
    position: relative;
  }

  .page-content blockquote::before {
    content: open-quote;
    font-size: 3rem;
    color: var(--page-accent);
    opacity: 0.2;
    position: absolute;
    top: -5px;
    left: 10px;
    font-family: Georgia, serif;
  }

  /* Code blocks */
  .page-content pre {
    background: #1e293b;
    color: #e2e8f0;
    padding: 20px;
    border-radius: 10px;
    overflow-x: auto;
    margin: 25px 0;
    font-size: 0.9rem;
  }

  .page-content code {
    background: #f1f5f9;
    color: #e11d48;
    padding: 3px 8px;
    border-radius: 4px;
    font-size: 0.9em;
  }

  /* Animations */
  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Animation classes */
  .fade-in { animation: fadeIn 0.8s ease-out forwards; }
  .fadeUp { animation: fadeInUp 0.8s ease-out forwards; }
  .delay-1 { animation-delay: 0.1s; }
  .delay-2 { animation-delay: 0.2s; }
  .delay-3 { animation-delay: 0.3s; }
  .delay-4 { animation-delay: 0.4s; }

  /* MOBILE SPECIFIC FIXES */
  @media (max-width: 480px) {
    .page-hero {
      padding: 35px 0 25px;
    }
    
    .page-title {
      font-size: 1.6rem;
    }
    
    .page-layout {
      margin: -15px auto 25px;
      padding: 0 8px;
    }
    
    .page-content {
      padding: 18px 12px;
      border-radius: 10px;
      margin-top: 10px;
    }

    .page-content::before {
      border-radius: 10px 10px 0 0;
    }
    
    .page-content h2 {
      font-size: 1.25rem;
    }
    
    .page-content h3 {
      font-size: 1.1rem;
    }
    
    .page-content p,
    .page-content li {
      font-size: 0.9rem;
    }
    
    .table-responsive {
      margin: 15px -12px;
    }

    /* Mobile Intro Card Layout */
    .intro-card {
      position: relative;
      padding: 20px 15px;
    }

    .intro-content h2 {
      padding-right: 0;
      margin-bottom: 15px;
    }

    .intro-content > p:first-of-type {
      padding-right: 0;
      margin-bottom: 15px;
    }

    .intro-image {
      position: static;
      width: 100%;
      text-align: center;
      margin: 15px 0;
    }

    .intro-image img {
      width: 150px;
      max-width: 50%;
      margin: 0 auto;
      display: block;
      background: none !important;
      box-shadow: none !important;
      padding: 0;
      border-radius: 0;
      border: none;
    }
  }

  @media (max-width: 360px) {
    .page-layout {
      padding: 0 6px;
    }
    
    .page-content {
      padding: 16px 10px;
    }
    
    .page-title {
      font-size: 1.5rem;
    }
  }

  /* TABLET STYLES */
  @media (min-width: 768px) {
