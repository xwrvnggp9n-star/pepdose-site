  border-color: var(--header-accent);
  box-shadow: 0 0 0 3px rgba(231, 76, 60, 0.2);
}

.header-search-input {
  flex: 1;
  padding: 8px 15px;
  background: transparent;
  border: none;
  color: var(--header-text);
  font-size: 0.9rem;
  font-weight: 500;
