    }
    
    .reference-list li {
      padding: 15px;
    }

    .table-responsive {
      margin: 25px 0;
      width: 100%;
    }
  }

  /* DESKTOP STYLES */
  @media (min-width: 1024px) {
    :root {
      --section-spacing: 35px;
      --content-padding: 45px;
      --hero-padding-mobile: 80px 0 60px;
      --card-radius: 16px;
    }
    
    .page-hero {
      padding: var(--hero-padding-mobile);
    }
    
    .page-title {
      font-size: 2.75rem;
      margin-bottom: 10px;
    }
    
    .page-layout {
      margin: -40px auto 60px;
      display: flex;
      gap: 40px;
      padding: 0 20px;
    }
    
    /* Show TOC on desktop */
    .toc-container {
      display: block;
      width: 300px;
      background: var(--page-card);
      border-radius: var(--card-radius);
      padding: 30px;
      position: sticky;
      top: 100px;
      height: fit-content;
      box-shadow: var(--page-shadow-lg);
      border: 1px solid var(--page-border);
      transition: all 0.3s ease;
    }
    
    .toc-container:hover {
      box-shadow: 0 12px 30px rgba(0,0,0,0.12);
    }
    
    .toc-title {
      font-size: 1.3rem;
      color: var(--page-secondary);
      margin-bottom: 20px;
      font-weight: 600;
      padding-bottom: 15px;
      border-bottom: 3px solid var(--page-accent);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .toc-title i {
      color: var(--page-accent);
      font-size: 1.1rem;
    }
    
    .nav-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    
    .nav-list li {
      margin-bottom: 4px;
    }
    
    .nav-list a {
      display: flex;
      align-items: center;
      color: var(--page-text);
      font-size: 0.95rem;
      padding: 10px 14px;
      border-radius: 8px;
      transition: all 0.3s ease;
      text-decoration: none;
      position: relative;
      overflow: hidden;
    }
    
    .nav-list a::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      height: 100%;
      width: 3px;
      background: var(--page-accent);
      transform: translateX(-100%);
      transition: transform 0.3s ease;
    }
    
    .nav-list a:hover {
      background: linear-gradient(90deg, rgba(231,76,60,0.1) 0%, transparent 100%);
      color: var(--page-accent);
      padding-left: 20px;
    }
    
    .nav-list a:hover::before {
      transform: translateX(0);
    }
    
    .nav-list a.active {
      background: linear-gradient(90deg, rgba(52,152,219,0.15) 0%, rgba(52,152,219,0.05) 100%);
      color: var(--page-primary);
      font-weight: 600;
    }
    
    .nav-list a.active::before {
      transform: translateX(0);
      background: var(--page-primary);
    }
    
    .nav-list a i {
      margin-right: 10px;
      width: 20px;
      text-align: center;
      font-size: 0.85rem;
      opacity: 0.7;
    }
    
    .page-content {
      flex: 1;
      max-width: 900px;
      padding: var(--content-padding);
      border-radius: var(--card-radius);
      overflow: hidden; /* Ensure line is contained on desktop */
    }

    .page-content::before {
      border-radius: var(--card-radius) var(--card-radius) 0 0;
    }
    
    .page-content h2 {
      font-size: 1.8rem;
      margin: 40px 0 22px;
    }
    
    .page-content h3 {
      font-size: 1.4rem;
      margin: 30px 0 15px;
    }
    
    .page-content p {
      font-size: 1.08rem;
      margin-bottom: 22px;
      line-height: 1.75;
    }

    .page-content ul li,
    .page-content ol li {
      font-size: 1.08rem;
      margin-bottom: 15px;
      line-height: 1.8;
    }

    .page-content ul li::before {
      left: 0;
      top: 12px;
      width: 8px;
      height: 8px;
    }

    .page-content ol li::before {
      width: 28px;
      height: 28px;
      font-size: 0.9rem;
    }
    
    /* Desktop Intro Card Layout */
    .intro-card {
      padding: 40px;
      position: relative;
    }

    .intro-content h2 {
      padding-right: 250px;
    }

    .intro-content > p:first-of-type {
      padding-right: 250px;
    }

    .intro-image {
      position: absolute;
      top: 35px;
      right: 40px;
      width: 200px;
    }

    .intro-image img {
      width: 100%;
      box-shadow: 0 6px 20px rgba(0,0,0,0.12);
    }
    
    .image-gallery {
      grid-template-columns: repeat(4, 1fr);
      margin: 30px 0;
    }
    
    .product-card {
      padding: 20px;
    }
    
    .product-card img {
      width: 140px;
      height: 140px;
    }
    
    .dosing-recon-wrapper header {
      padding: 35px;
    }
    
    .dosing-recon-wrapper header h2 {
      font-size: 1.8rem;
    }
    
    .dosing-recon-wrapper section {
      padding: 35px;
    }
    
    .dosing-recon-wrapper section h2 {
      font-size: 1.5rem;
      padding-left: 15px;
    }
    
    .reference-list li {
      padding: 20px;
      margin-bottom: 18px;
    }
  }

  /* LARGE DESKTOP */
  @media (min-width: 1440px) {
    .page-title {
      font-size: 3.25rem;
    }
    
    .toc-container {
      width: 320px;
      padding: 35px;
    }
    
    .page-content {
      padding: 50px;
    }
  }

  /* Print styles */
  @media print {
    .toc-container,
    .page-hero {
      display: none;
    }
    
    .page-layout {
      margin: 0;
      padding: 0;
    }
    
    .page-content {
      box-shadow: none;
      padding: 0;
      border: none;
    }

    .page-content::before {
      display: none;
    }
  }

  /* Kill shadow & white tile on Quick-Start image (global, all breakpoints) */
  .page-content .intro-card .intro-image,
  .page-content .intro-card .intro-image figure,
  .page-content .intro-card .intro-image .wp-block-image,
  .page-content .intro-card .intro-image img {
    background: transparent !important;
    box-shadow: none !important;
    filter: none !important;      /* in case a drop-shadow filter is applied */
    padding: 0 !important;
    border: 0 !important;
    border-radius: 0 !important;  /* avoid rounded "card" look */
  }

  /* === Custom bullets & numbers for .page-content (excluding references) === */
  .page-content ul:not(.reference-list),
  .page-content ol:not(.reference-list) {
    list-style: none !important;        /* kill default bullets/numbers */
    padding-left: 0 !important;         /* we'll indent on <li> instead */
    margin: 25px 0 30px;
  }

  /* Unordered list — red dot (excluding references) */
  .page-content ul:not(.reference-list) li {
    position: relative;
    padding-left: 35px;      /* space for the custom dot */
    line-height: 1.8;
    color: var(--page-text);
    margin-bottom: 15px;
  }

  .page-content ul:not(.reference-list) li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    width: 8px;
    height: 8px;
    background: var(--page-accent);      /* red */
    border-radius: 50%;
    box-shadow: 0 0 0 3px rgba(231,76,60,0.10);
  }

  /* Ordered list — blue numbered circle (excluding references) */
  .page-content ol:not(.reference-list) {
    counter-reset: pc-counter;
