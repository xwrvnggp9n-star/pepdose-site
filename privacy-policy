  position: relative;
  background: transparent;
}

.dropdown-menu li a::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 0;
  background: var(--header-accent);
  transition: height var(--transition-fast);
  border-radius: 2px;
}

.dropdown-menu li a:hover {
  background: #f0f7ff; /* FIXED: Light blue background on hover */
  color: #e74c3c !important; /* FIXED: Red text on hover */
  padding-left: 24px;
  font-weight: 600;
}

.dropdown-menu li a:hover::before {
  height: 70%;
}

/* Dropdown scrollbar */
.dropdown-menu::-webkit-scrollbar {
  width: 6px;
}

.dropdown-menu::-webkit-scrollbar-track {
  background: #f5f5f5;
  border-radius: 10px;
}

.dropdown-menu::-webkit-scrollbar-thumb {
  background: #3498db;
  border-radius: 10px;
}

.dropdown-menu::-webkit-scrollbar-thumb:hover {
  background: #2c3e50;
}

/************************************************************
 *                    HEADER SEARCH BAR
 ************************************************************/
.header-search {
  display: flex;
  align-items: center;
  gap: 10px;
}

.header-search-form {
  position: relative;
}

.header-search-wrapper {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
  border: 2px solid rgba(255, 255, 255, 0.2);
