  };

  // State management
  const state = {
    isLoading: false,
    isMobileMenuOpen: false,
    isMobileSearchOpen: false,
    navigationData: null
  };

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeHeader);
  } else {
    initializeHeader();
  }

  async function initializeHeader() {
    try {
      // Check cache first
      const cachedData = getCachedData();
      if (cachedData) {
        state.navigationData = cachedData;
        renderNavigation();
      } else {
        await loadNavigationData();
      }
      
      setupEventListeners();
      setupProgressBar();
      setupScrollEffects();
      
    } catch (error) {
      console.error('Failed to initialize header:', error);
      showErrorState();
    }
  }

  // Cache management
  function getCachedData() {
    try {
      const cached = localStorage.getItem(CONFIG.cache.key);
      if (!cached) return null;
      
      const { data, timestamp } = JSON.parse(cached);
      const isExpired = Date.now() - timestamp > CONFIG.cache.duration;
      
      if (isExpired) {
        localStorage.removeItem(CONFIG.cache.key);
        return null;
      }
      
      return data;
    } catch (error) {
      console.error('Cache read error:', error);
      return null;
    }
  }

  function setCachedData(data) {
    try {
      localStorage.setItem(CONFIG.cache.key, JSON.stringify({
        data,
        timestamp: Date.now()
      }));
    } catch (error) {
      console.error('Cache write error:', error);
    }
  }

  // API calls with retry logic
  async function fetchWithRetry(url, retries = CONFIG.api.retries) {
    for (let i = 0; i <= retries; i++) {
      try {
        const controller = new AbortController();
        const timeoutId = setTimeout(() => controller.abort(), CONFIG.api.timeout);
        
        const response = await fetch(url, { signal: controller.signal });
        clearTimeout(timeoutId);
        
        if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);
        return await response.json();
        
      } catch (error) {
        if (i === retries) throw error;
        await new Promise(resolve => setTimeout(resolve, 1000 * (i + 1)));
      }
    }
  }

  // Load navigation data
  async function loadNavigationData() {
    state.isLoading = true;
    showLoadingState();
    
    try {
      const navigationData = JSON.parse(JSON.stringify(CONFIG.navData));
      
      // Load submenus in parallel
      const loadPromises = navigationData.mainMenu.map(async (item) => {
        if (!item.parentSlug) return;
        
        try {
          // Get parent page ID
          const parents = await fetchWithRetry(`/wp-json/wp/v2/pages?slug=${item.parentSlug}&_fields=id`);
          if (!parents || !parents[0]) return;
          
          // Get children pages
          const children = await fetchWithRetry(
            `/wp-json/wp/v2/pages?parent=${parents[0].id}&per_page=100&_fields=title,link`
          );
          
          // Sort and format children
          item.submenu = children
            .map(child => ({
              title: formatTitle(child.title.rendered),
              url: child.link
            }))
            .sort(compareItems);
            
        } catch (error) {
          console.error(`Failed to load submenu for ${item.title}:`, error);
          item.error = true;
        }
      });
      
      await Promise.all(loadPromises);
      
      state.navigationData = navigationData;
      setCachedData(navigationData);
      renderNavigation();
      
    } catch (error) {
      console.error('Failed to load navigation:', error);
      showErrorState();
    } finally {
      state.isLoading = false;
    }
  }

  // Title formatting and sorting
  function formatTitle(title) {
    return title.replace(/[\s–—]*Dosage\s*Protocol/i, '').trim();
  }

  function parseItemForSort(title) {
    const clean = formatTitle(title);
    const match = clean.match(/(\d+(?:\.\d+)?)(?=\s*(?:mg|mcg|µg|g|ml|mL)\b)/i);
    const dose = match ? parseFloat(match[1]) : NaN;
    const base = match ? clean.slice(0, match.index).trim().toLowerCase() : clean.toLowerCase();
    return { base, dose, clean };
  }

  function compareItems(a, b) {
    const infoA = parseItemForSort(a.title);
    const infoB = parseItemForSort(b.title);
    
    if (infoA.base !== infoB.base) {
      return infoA.base.localeCompare(infoB.base);
    }
    
    if (!isNaN(infoA.dose) && !isNaN(infoB.dose) && infoA.dose !== infoB.dose) {
      return infoA.dose - infoB.dose;
    }
    
    return infoA.clean.localeCompare(infoB.clean);
  }

  // Render navigation
  function renderNavigation() {
    if (!state.navigationData) return;
    
    renderDesktopNav();
    renderMobileNav();
  }

  function renderDesktopNav() {
    const navList = document.querySelector('.main-nav > ul');
    if (!navList) return;
    
    navList.innerHTML = '';
    
    state.navigationData.mainMenu.forEach(item => {
      const li = document.createElement('li');
      
      if (item.submenu && item.submenu.length > 0) {
        li.classList.add('has-dropdown');
        li.innerHTML = `<a href="#" role="button" aria-expanded="false" aria-haspopup="true">${item.title}</a>`;
        
        const dropdown = document.createElement('ul');
        dropdown.className = 'dropdown-menu';
        dropdown.setAttribute('role', 'menu');
        
        if (item.title !== 'Single Peptides' && item.submenu.length > 15) {
          dropdown.classList.add('multi-column');
        }
        
        item.submenu.forEach(subitem => {
          const subLi = document.createElement('li');
          subLi.setAttribute('role', 'none');
          subLi.innerHTML = `<a href="${subitem.url}" role="menuitem">${subitem.title}</a>`;
          dropdown.appendChild(subLi);
        });
        
        li.appendChild(dropdown);
      } else if (item.error) {
        li.innerHTML = `<a href="#" class="nav-error">${item.title} (Error loading)</a>`;
      }
      
      navList.appendChild(li);
    });
  }

  function renderMobileNav() {
    const mobileList = document.querySelector('.mobile-nav-list');
    if (!mobileList) return;
    
    mobileList.innerHTML = '';
    
    state.navigationData.mainMenu.forEach((item, index) => {
      const li = document.createElement('li');
      
      if (item.submenu && item.submenu.length > 0) {
        const submenuId = `mobileSubmenu${index}`;
        li.innerHTML = `
          <a href="#" data-target="${submenuId}" role="button" aria-expanded="false" aria-controls="${submenuId}">
            ${item.title}
          </a>
        `;
        
        const submenu = document.createElement('ul');
        submenu.className = 'mobile-submenu';
        submenu.id = submenuId;
        submenu.setAttribute('role', 'menu');
        
        item.submenu.forEach(subitem => {
          const subLi = document.createElement('li');
          subLi.setAttribute('role', 'none');
          subLi.innerHTML = `<a href="${subitem.url}" role="menuitem">${subitem.title}</a>`;
          submenu.appendChild(subLi);
        });
        
        li.appendChild(submenu);
      } else if (item.error) {
        li.innerHTML = `<a href="#" class="nav-error">${item.title} (Error loading)</a>`;
      }
      
      mobileList.appendChild(li);
    });
  }

  // Loading and error states
  function showLoadingState() {
    const desktopNav = document.querySelector('.main-nav > ul');
    const mobileNav = document.querySelector('.mobile-nav-list');
    
    const loadingHTML = '<li class="nav-loading">Loading navigation...</li>';
    
    if (desktopNav) desktopNav.innerHTML = loadingHTML;
    if (mobileNav) mobileNav.innerHTML = loadingHTML;
  }

  function showErrorState() {
    const desktopNav = document.querySelector('.main-nav > ul');
    const mobileNav = document.querySelector('.mobile-nav-list');
    
    const errorHTML = '<li class="nav-error">Error loading navigation. <a href="#" onclick="location.reload()">Retry</a></li>';
    
    if (desktopNav) desktopNav.innerHTML = errorHTML;
    if (mobileNav) mobileNav.innerHTML = errorHTML;
  }

  // Event listeners
  function setupEventListeners() {
    // Mobile menu toggle
    const hamburgerBtn = document.getElementById('mobileHamburgerBtn');
    const mobilePanel = document.getElementById('mobileNavPanel');
    const mobileOverlay = document.getElementById('mobileOverlay');
    
    if (hamburgerBtn && mobilePanel && mobileOverlay) {
      hamburgerBtn.addEventListener('click', toggleMobileMenu);
      mobileOverlay.addEventListener('click', closeMobileMenu);
      
      // Close on escape key
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && state.isMobileMenuOpen) {
          closeMobileMenu();
        }
      });
    }
    
    // Mobile search toggle
    const mobileSearchToggle = document.getElementById('mobileSearchToggle');
    const mobileSearchOverlay = document.getElementById('mobileSearchOverlay');
    
    if (mobileSearchToggle && mobileSearchOverlay) {
      mobileSearchToggle.addEventListener('click', toggleMobileSearch);
      
      // Close search on escape
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && state.isMobileSearchOpen) {
          closeMobileSearch();
        }
      });
    }
    
    // Mobile submenu toggles
    const mobileNavList = document.querySelector('.mobile-nav-list');
    if (mobileNavList) {
      mobileNavList.addEventListener('click', handleMobileSubmenuClick);
    }
    
    // Desktop dropdown keyboard navigation
    const mainNav = document.querySelector('.main-nav');
    if (mainNav) {
      mainNav.addEventListener('keydown', handleDesktopNavKeyboard);
    }
  }

  function toggleMobileMenu() {
    state.isMobileMenuOpen = !state.isMobileMenuOpen;
    updateMobileMenuState();
  }

  function closeMobileMenu() {
    state.isMobileMenuOpen = false;
    updateMobileMenuState();
  }

  function updateMobileMenuState() {
    const hamburgerBtn = document.getElementById('mobileHamburgerBtn');
    const mobilePanel = document.getElementById('mobileNavPanel');
    const mobileOverlay = document.getElementById('mobileOverlay');
    
    if (state.isMobileMenuOpen) {
      hamburgerBtn.classList.add('active');
      hamburgerBtn.setAttribute('aria-expanded', 'true');
      mobilePanel.classList.add('active');
      mobileOverlay.classList.add('active');
      document.body.classList.add('mobile-menu-open');
    } else {
      hamburgerBtn.classList.remove('active');
      hamburgerBtn.setAttribute('aria-expanded', 'false');
      mobilePanel.classList.remove('active');
      mobileOverlay.classList.remove('active');
      document.body.classList.remove('mobile-menu-open');
    }
  }

  function toggleMobileSearch() {
    state.isMobileSearchOpen = !state.isMobileSearchOpen;
    const searchOverlay = document.getElementById('mobileSearchOverlay');
    const searchToggle = document.getElementById('mobileSearchToggle');
    
    if (state.isMobileSearchOpen) {
      searchOverlay.classList.add('active');
      searchToggle.classList.add('active');
      setTimeout(() => {
        const searchInput = searchOverlay.querySelector('input');
        if (searchInput) searchInput.focus();
      }, 300);
    } else {
      searchOverlay.classList.remove('active');
      searchToggle.classList.remove('active');
    }
  }

  function closeMobileSearch() {
    state.isMobileSearchOpen = false;
    const searchOverlay = document.getElementById('mobileSearchOverlay');
    const searchToggle = document.getElementById('mobileSearchToggle');
    searchOverlay.classList.remove('active');
    searchToggle.classList.remove('active');
  }

  function handleMobileSubmenuClick(e) {
    const link = e.target.closest('a[data-target]');
    if (!link) return;
    
    e.preventDefault();
    
    const submenuId = link.getAttribute('data-target');
    const submenu = document.getElementById(submenuId);
    if (!submenu) return;
    
    const isOpen = submenu.style.display === 'block';
    
    // Close all other submenus
    document.querySelectorAll('.mobile-submenu').forEach(menu => {
      if (menu.id !== submenuId) {
        menu.style.display = 'none';
        const toggle = document.querySelector(`[data-target="${menu.id}"]`);
        if (toggle) {
          toggle.classList.remove('submenu-open');
          toggle.setAttribute('aria-expanded', 'false');
        }
      }
    });
    
    // Toggle current submenu
    submenu.style.display = isOpen ? 'none' : 'block';
    link.classList.toggle('submenu-open', !isOpen);
    link.setAttribute('aria-expanded', !isOpen);
  }

  function handleDesktopNavKeyboard(e) {
    const currentItem = e.target.closest('li');
    if (!currentItem) return;
    
    const dropdown = currentItem.querySelector('.dropdown-menu');
    if (!dropdown) return;
    
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      const link = currentItem.querySelector('a');
      const isExpanded = link.getAttribute('aria-expanded') === 'true';
      link.setAttribute('aria-expanded', !isExpanded);
    }
  }

  // Progress bar
  function setupProgressBar() {
    const progressBar = document.getElementById('progressBar');
    if (!progressBar) return;
    
    let ticking = false;
    
    function updateProgressBar() {
      const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
      const scrollProgress = (window.scrollY / scrollHeight) * 100;
      
      progressBar.style.width = `${scrollProgress}%`;
      progressBar.setAttribute('aria-valuenow', Math.round(scrollProgress));
      
      ticking = false;
    }
    
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateProgressBar);
        ticking = true;
      }
    }, { passive: true });
  }

  // Scroll effects
  function setupScrollEffects() {
    const header = document.getElementById('siteHeader');
    if (!header) return;
    
    let lastScroll = 0;
    let ticking = false;
    
    function updateHeader() {
      const currentScroll = window.scrollY;
      
      if (currentScroll > 10) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
      
      lastScroll = currentScroll;
      ticking = false;
    }
    
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(updateHeader);
        ticking = true;
      }
    }, { passive: true });
  }
})();
</script>

