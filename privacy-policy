    }

    .page-content::before {
      border-radius: var(--card-radius) var(--card-radius) 0 0;
    }
    
    .page-content h2 {
      font-size: 1.6rem;
      margin: 35px 0 20px;
    }
    
    .page-content h3 {
      font-size: 1.3rem;
