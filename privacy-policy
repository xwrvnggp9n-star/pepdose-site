  // Set current year
  document.getElementById('currentYear').textContent = new Date().getFullYear();
  
  // Back to Top functionality
  const backToTop = document.getElementById('backToTop');
  
  window.addEventListener('scroll', function() {
    if (window.scrollY > 300) {
      backToTop.classList.add('visible');
    } else {
      backToTop.classList.remove('visible');
    }
  });
  
  backToTop.addEventListener('click', function() {
    window.scrollTo({
      top: 0,
      behavior: 'smooth'
    });
  });
  
  // FunnelKit Newsletter form handler
  window.handleNewsletterSubmit = function(e) {
    e.preventDefault();
    
    const form = e.target;
    const emailInput = form.querySelector('input[type="email"]');
    const submitButton = form.querySelector('button[type="submit"]');
    const email = emailInput.value;
    
    // Remove any existing messages
    const existingMsg = form.querySelector('.form-message');
    if (existingMsg) existingMsg.remove();
    
    // Disable form while submitting
    emailInput.disabled = true;
    submitButton.disabled = true;
    const originalText = submitButton.textContent;
    submitButton.textContent = 'Subscribing...';
    
    // Create FormData object
    const formData = new FormData();
    formData.append('action', 'funnelkit_newsletter_subscribe');
    formData.append('email', email);
    
    // Get AJAX URL - this is more reliable
    const ajaxUrl = 'https://peptidedosages.com/wp-admin/admin-ajax.php';
    
    // Send AJAX request
    fetch(ajaxUrl, {
      method: 'POST',
      credentials: 'same-origin',
      body: formData
    })
    .then(response => {
      if (!response.ok) {
        throw new Error('Network response was not ok');
      }
      return response.json();
    })
    .then(data => {
      if (data.success) {
        // Success message with animation
        submitButton.style.backgroundColor = '#27ae60';
        submitButton.textContent = '✓ Subscribed!';
        
        // Show success message
        const successMsg = document.createElement('div');
        successMsg.className = 'form-message';
        successMsg.style.cssText = 'color: #27ae60; margin-top: 10px; font-size: 0.9rem; font-weight: 500;';
        successMsg.textContent = data.data || 'Thank you for subscribing!';
        form.appendChild(successMsg);
        
        // Reset form after delay
        setTimeout(() => {
          form.reset();
          submitButton.style.backgroundColor = '';
          submitButton.textContent = originalText;
          const msg = form.querySelector('.form-message');
          if (msg) msg.remove();
        }, 3000);
      } else {
        // Error message
        submitButton.style.backgroundColor = '#e74c3c';
        submitButton.textContent = 'Try Again';
        
        const errorMsg = document.createElement('div');
        errorMsg.className = 'form-message';
        errorMsg.style.cssText = 'color: #e74c3c; margin-top: 10px; font-size: 0.9rem; font-weight: 500;';
        errorMsg.textContent = data.data || 'Please enter a valid email address.';
        form.appendChild(errorMsg);
        
        setTimeout(() => {
          submitButton.style.backgroundColor = '';
          submitButton.textContent = originalText;
          const msg = form.querySelector('.form-message');
          if (msg) msg.remove();
        }, 3000);
      }
    })
    .catch(error => {
      console.error('Subscription error:', error);
      
      // Try a simpler fallback method
      if (email && email.includes('@')) {
        submitButton.style.backgroundColor = '#f39c12';
        submitButton.textContent = 'Saved!';
        
        const msg = document.createElement('div');
        msg.className = 'form-message';
        msg.style.cssText = 'color: #f39c12; margin-top: 10px; font-size: 0.9rem;';
        msg.textContent = 'Thank you! We\'ll add you to our list.';
        form.appendChild(msg);
        
        // Store in localStorage as backup
        const subscribers = JSON.parse(localStorage.getItem('newsletter_subscribers') || '[]');
        if (!subscribers.includes(email)) {
          subscribers.push(email);
          localStorage.setItem('newsletter_subscribers', JSON.stringify(subscribers));
        }
        
        setTimeout(() => {
          form.reset();
          submitButton.style.backgroundColor = '';
          submitButton.textContent = originalText;
          const message = form.querySelector('.form-message');
          if (message) message.remove();
        }, 3000);
      } else {
        submitButton.style.backgroundColor = '#e74c3c';
        submitButton.textContent = 'Error!';
        
        setTimeout(() => {
          submitButton.style.backgroundColor = '';
          submitButton.textContent = originalText;
        }, 2000);
      }
    })
    .finally(() => {
      // Re-enable form
      emailInput.disabled = false;
      submitButton.disabled = false;
    });
  };
})();
</script>

