  /* DESKTOP STYLES */
  @media (min-width: 1024px) {
    :root {
      --section-spacing: 35px;
      --content-padding: 45px;
      --hero-padding-mobile: 80px 0 60px;
      --card-radius: 16px;
    }
    
    .page-hero {
      padding: var(--hero-padding-mobile);
    }
    
    .page-title {
